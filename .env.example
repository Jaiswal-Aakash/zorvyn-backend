# Copy to .env and fill in your values:
#   cp .env.example .env

PORT=3000

# PostgreSQL (e.g. Supabase). Use the pooler URL for serverless / pooled connections.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=10&sslmode=require"

# Used to sign and verify JWTs — use a long random string in production.
JWT_SECRET=change-it-to-a-long-random-secret

# Allowed browser origin for CORS (your frontend URL).
CORS_ORIGIN=http://localhost:3000
